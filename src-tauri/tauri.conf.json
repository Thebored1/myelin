{
	"$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
	"productName": "myelin",
	"version": "0.2.0",
	"identifier": "com.paper.myelin",
	"build": {
		"frontendDist": "../build",
		"devUrl": "http://localhost:1420",
		"beforeDevCommand": "npm run dev",
		"beforeBuildCommand": "npm run build"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "myelin",
				"width": 1440,
				"height": 900,
				"minWidth": 850,
				"minHeight": 480,
				"resizable": true,
				"fullscreen": false,
				"decorations": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": ["nsis"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"resources": {
			"resources/bin": "bin"
		},
		"android": {
			"debugApplicationIdSuffix": ".debug"
		}
	}
}
